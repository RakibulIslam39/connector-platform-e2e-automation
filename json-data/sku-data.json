{
  "_meta": {
    "description": "SKU generation data for Connector Platform automated testing",
    "lastUpdated": "2026-05-22",
    "source": "Derived from live API: /wp-json/connector-platform/v1/attributes-mapping + /products"
  },
  "masterSkuFormula": {
    "pattern": "{product_base_sku}-{size_sku}-{color_sku}[-modifier_skus]",
    "rules": [
      "product_base_sku comes from the product's own 'sku' field (e.g. VEN-ANBS)",
      "size_sku is the 4-digit WxH code from the Size/PartnerSizes mapping (e.g. 3636 = 36\"x36\")",
      "color_sku is the code from PartnerColors mapping (e.g. RAW, PRM, USCDSAW)",
      "Modifiers are appended in order: IncreaseDepth, ReduceHeight, CrownMolding, ExtendChimney, SolidBottom",
      "Floating Shelves use SelectWidth sku instead of Size (e.g. FSW30)"
    ]
  },
  "shortSkuFormula": {
    "description": "Short SKU = full Master SKU without the product base prefix. Used in HoodslyHub order validation.",
    "pattern": "{size_sku}-{color_sku}[-modifier_skus]",
    "examples": [
      { "masterSku": "VEN-ANBS-3636-RAW", "shortSku": "3636-RAW" },
      { "masterSku": "VEN-CCX-3036-PRM", "shortSku": "3036-PRM" },
      { "masterSku": "VEN-MCX-3036-USCDSAW-RH2", "shortSku": "3036-USCDSAW-RH2" },
      { "masterSku": "VEN-ANBS-4836-HOOANT00001-SB", "shortSku": "4836-HOOANT00001-SB" },
      { "masterSku": "VEN-FLS-FSW30-RAW", "shortSku": "FSW30-RAW" }
    ]
  },
  "masterSkuExamples": [
