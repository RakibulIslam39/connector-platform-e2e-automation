    "endpoint": "POST https://api-v3.hoodslyhub.com/v1/order/create",
    "endpoint_legacy_shim": "POST /wp-json/cliqstudio/v1/order",
    "auth_header": "X-API-Key: {{CLIQ_API_KEY}}",
    "notes": [
      "order_id prefix convention: CLIQ-{number} (e.g. CLIQ-27006985)",
      "origin: 'CLIQ' (uppercase)",
      "vent: comma-separated ventilation SKUs — TW* prefix or 698-* prefix, merged onto hood item",
      "mod_sku: comma-separated HUMAN-READABLE modifier descriptions (e.g. 'Extend Chimney 6\",Reduce Height by 1\"')",
      "note: optional per-line-item note for Hub operators",
      "instruction: top-level field for BOL/special handling instructions",
      "No billing address — Hub copies billing from shipping",
      "Hub order id: CLIQ-{order_id}-hood"
    ]
  },
