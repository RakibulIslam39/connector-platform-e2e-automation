{
  "_meta": {
    "vendor": "Prime",
    "format": "Prime native payload — verbatim as sent to Hub",
    "endpoint": "POST https://api-v3.hoodslyhub.com/v1/order/create",
    "endpoint_legacy_shim": "POST /wp-json/prime/v1/order",
    "auth_header": "X-API-Key: {{PRIME_API_KEY}}",
    "notes": [
      "line_items wrapper contains order_total and total_quantity alongside the line_items array",
      "product_cat and product_catName are ARRAYS (not strings)",
      "item_total_tax is a string decimal on each line item",
      "color_options is null when not applicable",
      "shipping_lines is an OBJECT (not array) — contains limited_access and appt_required booleans",
      "set_paid: 'false' or 'true' string — controls payment state in Hub",
      "rl_tracking_number, bill_of_landing_id, bol_pdf, shipping_label are top-level fields (empty on creation)",
      "origin: 'prime' (lowercase)"
    ]
  },
