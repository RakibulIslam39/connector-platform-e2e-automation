auth-state/*.json

# Logs
logs/*.log
logs/*.json

# One-off / scratch data captured from probe scripts
scripts/_raw-*.json

# OS / IDE artifacts
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
.cursor/
*.swp
*.swo

# Build outputs
dist/
build/

